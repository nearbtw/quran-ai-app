{
  "1": [
    {"id":"1:1","text":"الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ","audio":"","number":1},
    {"id":"1:2","text":"الرَّحْمَٰنِ الرَّحِيمِ","audio":"","number":2},
    {"id":"1:3","text":"مَالِكِ يَوْمِ الدِّينِ","audio":"","number":3},
    {"id":"1:4","text":"إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ","audio":"","number":4},
    {"id":"1:5","text":"اهْدِنَا الصِّرَاطَ الْمُسْتَقِيمَ","audio":"","number":5},
    {"id":"1:6","text":"صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ","audio":"","number":6},
    {"id":"1:7","text":"غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِّينَ","audio":"","number":7}
  ],
  "2": [
    {"id":"2:1","text":"الم","audio":"","number":1},
    {"id":"2:2","text":"ذَٰلِكَ الْكِتَابُ لَا رَيْبَ ۛ فِيهِ ۛ هُدًى لِّلْمُتَّقِينَ","audio":"","number":2},
    {"id":"2:3","text":"الَّذِينَ يُؤْمِنُونَ بِالْغَيْبِ وَيُقِيمُونَ الصَّلَاةَ وَمِمَّا رَزَقْنَاهُمْ يُنفِقُونَ","audio":"","number":3},
    {"id":"2:4","text":"وَالَّذِينَ يُؤْمِنُونَ بِمَا أُنزِلَ إِلَيْكَ وَمَا أُنزِلَ مِن قَبْلِكَ وَبِالْآخِرَةِ هُمْ يُوقِنُونَ","audio":"","number":4},
    {"id":"2:5","text":"أُولَٰئِكَ عَلَىٰ هُدًى مِّن رَّبِّهِمْ ۖ وَأُولَٰئِكَ هُمُ الْمُفْلِحُونَ","audio":"","number":5}
  ],
  "112": [
    {"id":"112:1","text":"قُلْ هُوَ اللَّهُ أَحَدٌ","audio":"","number":1},
    {"id":"112:2","text":"اللَّهُ الصَّمَدُ","audio":"","number":2},
    {"id":"112:3","text":"لَمْ يَلِدْ وَلَمْ يُولَدْ","audio":"","number":3},
    {"id":"112:4","text":"وَلَمْ يَكُن لَّهُ كُفُوًا أَحَدٌ","audio":"","number":4}
  ]
}
